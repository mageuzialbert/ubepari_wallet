# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored — do not commit it.
# Do not commit this file with real values filled in either.

# ---------- Site ----------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------- SMS gateway (messaging-service.co.tz) ----------
# Server-side only. Never expose these to the browser.
SMS_USERNAME=
SMS_PASSWORD=
SMS_SENDER_ID=Ubepari Pc
SMS_BASE_URL=https://messaging-service.co.tz/link/sms/v1/text/single

# ---------- Evmark payments ----------
# Daily hash: md5(EVMARK_USER + "|" + DD-MM-YYYY)
EVMARK_USER=ipab
EVMARK_API_SOURCE=iPAB
EVMARK_MNO_URL=https://vodaapi.evmak.com/prd/
EVMARK_CARD_URL=https://api.evmak.com/card/test/api/
EVMARK_CARD_PAY_TO=iPAB International

# Webhook URLs exposed to Evmark — must be publicly reachable.
# In prod these point at the Vercel deployment; in dev use ngrok.
EVMARK_MNO_CALLBACK_URL=http://localhost:3000/api/payments/mno/callback
EVMARK_CARD_CALLBACK_URL=http://localhost:3000/api/payments/card/callback

# ---------- OpenAI (AI Tech Tips) ----------
# Server-side only.
OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_MODEL=gpt-4o-mini

# ---------- Google Maps ----------
# Client-exposed (loaded in browser). Restrict by HTTP referrer in GCP Console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ---------- Supabase ----------
# From Project Settings -> API in the Supabase dashboard.
# SERVICE_ROLE and JWT_SECRET are server-only — never expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
